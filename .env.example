# ═══════════════════════════════════════════════════════════════
#  ВТОРНИК — Переменные окружения (ШАБЛОН)
#  Скопируйте в .env и заполните значениями
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
#  LOCAL DEVELOPMENT (Docker)
# ═══════════════════════════════════════════════════════════════

# Supabase Local
VITE_SUPABASE_URL=http://localhost:3000
VITE_SUPABASE_ANON_KEY=your-super-secret-jwt-token-change-in-production

# GoTrue Auth (локальный)
VITE_GOTRUE_URL=http://localhost:9999

# JWT Secret (должен совпадать с docker-compose.yml)
JWT_SECRET=your-super-secret-jwt-token-change-in-production

# ═══════════════════════════════════════════════════════════════
#  PRODUCTION (Supabase Cloud)
# ═══════════════════════════════════════════════════════════════

# Supabase Production
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your-production-anon-key

# ═══════════════════════════════════════════════════════════════
#  Приложение
# ═══════════════════════════════════════════════════════════════

VITE_APP_NAME=ВТОРНИК
VITE_APP_URL=http://localhost:3003

# Порты
VITE_PORT=3003
VITE_REST_PORT=3000
VITE_DB_PORT=54322
VITE_AUTH_PORT=9999

# ═══════════════════════════════════════════════════════════════
#  Опционально: Sentry (error tracking)
# ═══════════════════════════════════════════════════════════════

# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
